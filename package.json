{
  "name": "claude-hooks-listener",
  "version": "1.0.0",
  "description": "CLI tool that runs a Claude agent and listens to all hook events in real-time",
  "type": "module",
  "bin": {
    "claude-hooks": "./dist/index.js",
    "claude-hook-handler": "./dist/handler.js"
  },
  "scripts": {
    "build": "prisma generate && tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "db:push": "DATABASE_URL=\"file:$HOME/.claude/hook-handler.db\" prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "latest",
    "@anthropic-ai/sdk": "^0.78.0",
    "@prisma/adapter-better-sqlite3": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "better-sqlite3": "^12.6.2",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "prisma": "^7.4.2",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
