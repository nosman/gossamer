{
  "name": "gossamer-app",
  "version": "1.0.0",
  "private": true,
  "repository": "https://github.com/nosman/gossamer",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "electron-vite build && electron-builder",
    "dist:mac": "electron-vite build && electron-builder --mac"
  },
  "build": {
    "appId": "com.nosman.gossamer",
    "productName": "Gossamer",
    "directories": {
      "buildResources": "resources",
      "output": "release"
    },
    "files": [
      "out/**"
    ],
    "extraResources": [
      { "from": "../dist",              "to": "server/dist" },
      { "from": "../node_modules",      "to": "server/node_modules" },
      { "from": "../prisma/schema.prisma", "to": "server/prisma/schema.prisma" },
      { "from": "../prisma/generated",  "to": "server/prisma/generated" },
      { "from": "../package.json",      "to": "server/package.json" },
      { "from": "resources/server-launcher.cjs", "to": "server/server-launcher.cjs" }
    ],
    "mac": {
      "category": "public.app-category.developertools",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ]
    },
    "dmg": {
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  },
  "dependencies": {
    "@mantine/core": "^8.3.16",
    "@mantine/hooks": "^8.3.16",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "diff2html": "^3.4.56",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^32.3.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.5.8",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "typescript": "^5.5.0",
    "vite": "^5.4.21",
    "electron-builder": "^25.1.8"
  }
}
