{
  "name": "gossamer-vscode",
  "displayName": "Gossamer",
  "description": "View Entire CLI session history and logs inside VS Code",
  "version": "0.1.0",
  "publisher": "gossamer",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["workspaceContains:.entire/settings.json"],
  "type": "module",
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gossamer.openPanel",
        "title": "Gossamer: Open Session Viewer"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gossamer",
          "title": "Gossamer",
          "icon": "$(history)"
        }
      ]
    }
  },
  "scripts": {
    "build": "npm run build:extension && npm run build:webview",
    "build:extension": "tsc -p tsconfig.extension.json",
    "build:webview": "vite build",
    "dev:webview": "vite",
    "watch": "tsc -p tsconfig.extension.json --watch"
  },
  "dependencies": {
    "@gossamer/core": "*",
    "@mantine/core": "^7.0.0",
    "@mantine/hooks": "^7.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  }
}
